{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Telegram Context Retrieval Tool Contract",
  "type": "object",
  "properties": {
    "request": {
      "type": "object",
      "properties": {
        "chat_id": { "type": "integer" },
        "query": { "type": "string" },
        "limit": { "type": "integer", "minimum": 1, "maximum": 50, "default": 8 },
        "since": { "type": "string", "format": "date-time" }
      },
      "required": ["chat_id"]
    },
    "response": {
      "type": "object",
      "properties": {
        "chat_id": { "type": "integer" },
        "query": { "type": "string" },
        "returned": { "type": "integer" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "message_id": { "type": "integer" },
              "sender_id": { "type": ["integer", "null"] },
              "chat_title": { "type": ["string", "null"] },
              "message": { "type": "string" },
              "date": { "type": ["string", "null"], "format": "date-time" },
              "source": { "type": "string" },
              "score": { "type": "number" }
            },
            "required": ["message_id", "message", "source", "score"]
          }
        }
      },
      "required": ["chat_id", "returned", "items"]
    }
  },
  "required": ["request", "response"]
}
