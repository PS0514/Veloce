{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Z.AI Task Extraction Schema",
  "type": "object",
  "properties": {
    "analysis_metadata": {
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "source_detected": { "type": "string" }
      }
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "enum": ["meeting", "deadline", "task"] },
          "title": { "type": "string" },
          "start_time": { "type": ["string", "null"], "description": "ISO 8601 format" },
          "end_time": { "type": ["string", "null"] },
          "description": { "type": "string" },
          "confidence_score": { "type": "number", "minimum": 0, "maximum": 1 },
          "needs_clarification": { "type": "boolean" },
          "clarification_question": { "type": ["string", "null"] }
        },
        "required": ["type", "title", "confidence_score", "needs_clarification"]
      }
    }
  }
}