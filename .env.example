# ─────────────────────────────────────────────────────────────
# Veloce — Environment Configuration (.env)
#
# This file contains STATIC secrets and infrastructure settings.
# It is NEVER modified by the application at runtime.
#
# Runtime-mutable values (OAuth tokens, selected channels,
# keywords, calendar ID) are stored in  data/veloce_config.json
# and managed through the setup wizard UI.
# ─────────────────────────────────────────────────────────────

# Telegram
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Listener / Orchestrator
N8N_WEBHOOK_URL=http://127.0.0.1:8000/veloce-task-scheduler
VELOCE_ORCHESTRATOR_URL=http://127.0.0.1:8000/veloce-task-scheduler
VELOCE_DB_PATH=data/veloce.db
GENERIC_TIMEZONE=Asia/Kuala_Lumpur

# GLM (uses official zai-sdk, no URL needed)
ZAI_API_KEY=
ZAI_MODEL=glm-5.1

# Google Calendar integration
ENABLE_GOOGLE_SYNC=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
